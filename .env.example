# ============================================
# RantAI Agents - Environment Configuration
# ============================================
# Copy this file to .env and configure your settings
# Run: cp .env.example .env
#
# ─── Deployment mode — read this first ───
#
# This platform runs in two modes. Choose one, then configure its section:
#
#   CLOUD MODE (default, turnkey)
#     • AI / chat / embeddings / vision → OpenRouter (one API key)
#     • Web search → Perplexity via OpenRouter
#     • Minimum set: OPENROUTER_API_KEY + DATABASE_URL + SURREAL_DB_*
#
#   ON-PREM MODE (fully self-hosted, air-gap-friendly)
#     • Vision extraction → your vLLM (Qwen3-VL-30B-A3B or GLM-4.6V)
#     • Embeddings       → your Text Embedding Inference (Qwen3-Embedding-8B)
#     • Web search       → your SearXNG (bundled in docker-compose.yml)
#     • OpenRouter key optional (or blank) — used only as a fallback if any
#       on-prem endpoint is misconfigured.
#
# Look for the "MODE A" / "MODE B" / "CLOUD MODE" / "ON-PREM MODE" markers
# in each section below — they show exactly which vars to set per mode.

# ============================================
# DATABASE (Required)
# ============================================
# PostgreSQL connection (Docker default provided)
DATABASE_URL="postgresql://horizonlife:horizonlife_secret@localhost:5432/horizonlife_insurance?schema=public"

# ============================================
# VECTOR DATABASE (Required)
# ============================================
# SurrealDB for RAG embeddings storage
SURREAL_DB_URL="ws://localhost:8000/rpc"
SURREAL_DB_USER="root"
SURREAL_DB_PASS="root"
SURREAL_DB_NAMESPACE="rantai"
SURREAL_DB_DATABASE="knowledge"

# ============================================
# KNOWLEDGE BASE / RAG PIPELINE
# ============================================
# Benched on 40-doc mixed corpus (30 resumes + 10 Indonesian scans). See:
#   docs/superpowers/specs/2026-04-22-smart-router-extractor-design.md
#   docs/superpowers/plans/2026-04-22-smart-router-extractor.md
#
# ─────────────────────────────────────────────
# STEP 1 — CHOOSE AN EXTRACTION PATH (pick ONE)
# ─────────────────────────────────────────────
# All four are shipped. Pick based on your deployment + priorities:
#
#   (A) SMART ROUTER        → fastest + highest accuracy overall (RECOMMENDED)
#   (B) ALWAYS-OCR, cloud   → simple; every doc hits gpt-4.1-nano via OpenRouter
#   (C) ALWAYS-OCR, on-prem → air-gapped, every doc hits MinerU sidecar
#   (D) HYBRID              → MinerU structure + unpdf text overlay (niche; mostly superseded by A)

# ── (A) SMART ROUTER — RECOMMENDED DEFAULT ──
# Runs unpdf first (50 ms, free), falls through to the configured OCR engine
# only when heuristics detect a scan, table-heavy layout, or garbled text.
# Bench: 98% coverage @ 1.1 s avg — beats B/C/D on both axes on our suite.
KB_EXTRACT_PRIMARY="smart"
KB_EXTRACT_SMART_FALLBACK="openai/gpt-4.1-nano"        # cloud default. Change to "mineru" for on-prem.
# For on-prem smart (requires services/mineru-server/ sidecar running):
#   KB_EXTRACT_SMART_FALLBACK="mineru"
#   KB_EXTRACT_MINERU_BASE_URL="http://localhost:8100"

# ── (B) ALWAYS-OCR via gpt-4.1-nano (cloud only) ──
# Every doc goes through OpenRouter. No local heuristic shortcut.
# Use if you want predictable behavior over the 98%/1.1 s smart-router win.
# KB_EXTRACT_PRIMARY="openai/gpt-4.1-nano"              # any OpenRouter vision model id works
# KB_EXTRACT_FALLBACK="unpdf"                           # ingest still progresses if OCR fails

# ── (C) ALWAYS-OCR via MinerU (on-prem, air-gap OK) ──
# Launch the sidecar one-time before starting the app:
#   source ~/vllm-env/bin/activate
#   CUDA_VISIBLE_DEVICES=0 FLASHINFER_DISABLE_VERSION_CHECK=1 \
#     uvicorn services.mineru-server.server:app --host 0.0.0.0 --port 8100
# KB_EXTRACT_PRIMARY="mineru"
# KB_EXTRACT_MINERU_BASE_URL="http://localhost:8100"
# KB_EXTRACT_FALLBACK="unpdf"

# ── (D) HYBRID — MinerU structure + unpdf char fidelity (legacy) ──
# Runs both in parallel, merges outputs. Requires MinerU sidecar.
# Superseded by (A) smart router on our benches; kept as an option for corpora
# where the merge behavior proves useful on your data.
# KB_EXTRACT_PRIMARY="hybrid"
# KB_EXTRACT_MINERU_BASE_URL="http://localhost:8100"

# ─────────────────────────────────────────────
# STEP 2 — EMBEDDING (same for all extraction paths)
# ─────────────────────────────────────────────
KB_EMBEDDING_MODEL="qwen/qwen3-embedding-8b"            # Apache-2.0, 4096 dim, multilingual
KB_EMBEDDING_DIM="4096"
# On-prem override (TEI serving Qwen3-Embedding-8B):
#   KB_EMBEDDING_MODEL="Qwen/Qwen3-Embedding-8B"        # match your TEI --served-model-name
#   KB_EMBEDDING_BASE_URL="http://tei:8080/embed"       # see advanced section below

# ─────────────────────────────────────────────
# STEP 3 — RETRIEVAL BEHAVIOUR (optional tuning)
# ─────────────────────────────────────────────
# All three features below are opt-in. BM25 is on because it's free; the others
# trade latency/cost for accuracy. Enable them as you need them.

# BM25 + dense hybrid retrieval. +15 ms/query, +2-3 pts hit@1. Free.
KB_HYBRID_BM25_ENABLED="true"

# LLM rerank after top-K cosine. +1.7 s/query, +5.7 pts hit@1.
KB_RERANK_ENABLED="false"
KB_RERANK_MODEL="openai/gpt-4.1-nano"                   # override to a local vLLM model id on-prem
KB_RERANK_INITIAL_K="20"
KB_RERANK_FINAL_K="5"

# Contextual Retrieval (Anthropic 2024): per-chunk context prefix at ingest.
# +3-8 pts hit@1 on ambiguous chunks, +50% ingest latency. To enable:
#   1. Set this to "true"
#   2. bun run kb:apply-fts-schema      (adds contextual_prefix field + FTS index)
#   3. bun run kb:backfill-contextual   (populates prefixes for existing chunks)
KB_CONTEXTUAL_RETRIEVAL_ENABLED="false"
# KB_CONTEXTUAL_RETRIEVAL_MODEL="openai/gpt-4.1-nano"   # default: matches KB_EXTRACT_PRIMARY

# Query expansion — LLM generates N paraphrases at query time.
# +400 ms/query, +2-4 pts hit@1.
KB_QUERY_EXPANSION_ENABLED="false"
# KB_QUERY_EXPANSION_MODEL="openai/gpt-4.1-nano"
# KB_QUERY_EXPANSION_PARAPHRASES="3"

# ============================================
# ─── ADVANCED: ON-PREM / AIR-GAPPED ENDPOINTS ─
# ============================================
# Only needed for air-gapped deployment. Leave unset for cloud mode — the
# defaults point at OpenRouter and use OPENROUTER_API_KEY.
#
# Pattern per endpoint: <name>_BASE_URL + <name>_API_KEY. The API_KEY falls
# back to OPENROUTER_API_KEY when blank, so often only BASE_URL is needed.

# MinerU2.5-Pro sidecar (used when KB_EXTRACT_PRIMARY="mineru" / "hybrid"
# or KB_EXTRACT_SMART_FALLBACK="mineru"):
#   Launch per services/mineru-server/README.md
# KB_EXTRACT_MINERU_BASE_URL="http://mineru:8100"

# Vision-LLM extractor (used when KB_EXTRACT_PRIMARY or KB_EXTRACT_SMART_FALLBACK
# is a chat-model id, e.g. "Qwen/Qwen3-VL-30B-A3B-Instruct-FP8"):
#   Launch: vllm serve <model> --port 8000
# KB_EXTRACT_VISION_BASE_URL="http://vllm:8000/v1/chat/completions"
# KB_EXTRACT_VISION_API_KEY=""

# Embedding endpoint (TEI serving Qwen3-Embedding-8B):
#   Launch: text-embeddings-router --model-id Qwen/Qwen3-Embedding-8B
# KB_EMBEDDING_BASE_URL="http://tei:8080/embed"
# KB_EMBEDDING_API_KEY=""

# ============================================
# AUTHENTICATION (Required)
# ============================================
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# AI / LLM GATEWAY
# ============================================
# CLOUD MODE (default): all AI calls route through OpenRouter.
#   Get a key at https://openrouter.ai/keys
#   One key unlocks chat, embeddings, rerank, and web-search (via Perplexity).
#
# ON-PREM MODE: leave OPENROUTER_API_KEY blank (or unset) and set the per-endpoint
#   base-URL + api-key pairs under KNOWLEDGE BASE section above + WEB SEARCH section below.
OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"

# ============================================
# S3 STORAGE (Required for file uploads)
# ============================================
# RustFS S3-compatible storage (Docker)
# Console: http://localhost:9001
# Default credentials: rustfsadmin / rustfsadmin
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="rustfsadmin"
S3_SECRET_ACCESS_KEY="rustfsadmin"
S3_BUCKET="rantai-files"
S3_REGION="us-east-1"
S3_ENABLE_PATH_STYLE="1"
S3_PRESIGNED_URL_EXPIRE="7200"

# ============================================
# OCR PIPELINE (Optional - for document OCR)
# ============================================
# Ollama endpoint for local OCR models
# Docker: http://ollama:11434 | Local: http://localhost:11434
OLLAMA_ENDPOINT="http://localhost:11434"
OLLAMA_TIMEOUT="120000"

# MODEL SELECTION - Choose based on your hardware:
#
# ┌─────────────────┬────────────────────────────────────────┐
# │ Hardware        │ Recommended Models                     │
# ├─────────────────┼────────────────────────────────────────┤
# │ CPU-Only        │ moondream, qwen3-vl:2b                 │
# │ 4-6GB VRAM      │ glm-ocr (recommended), moondream       │
# │ 8-12GB VRAM     │ glm-ocr, qwen3-vl:8b                   │
# │ 16GB+ VRAM      │ glm-ocr (fast), minicpm-v:4.5 (best)   │
# └─────────────────┴────────────────────────────────────────┘
#
# Model Details:
#   glm-ocr       - 0.9B params, 2-3GB VRAM, 94.62% accuracy, fast
#   moondream     - 1.8B params, 3-4GB RAM, CPU-friendly
#   qwen3-vl:2b   - 2B params, 4GB, multilingual
#   qwen3-vl:8b   - 8B params, 6-8GB, better quality
#   minicpm-v:4.5 - 8B params, 10-12GB, SOTA handwriting

# Default model for general OCR
OCR_MODEL_DEFAULT="glm-ocr"

# Model for handwritten text (use minicpm-v:4.5 if you have 16GB+ VRAM)
OCR_MODEL_HANDWRITTEN="glm-ocr"

# Model for tables and forms
OCR_MODEL_TABLE="glm-ocr"

# Model for figures and diagrams
OCR_MODEL_FIGURE="glm-ocr"

# Fallback to OpenRouter if Ollama fails (recommended: true)
OCR_ENABLE_FALLBACK="true"
OCR_FALLBACK_MODEL="openai/gpt-4o-mini"

# ============================================
# CODE INTERPRETER (Optional - for sandboxed code execution)
# ============================================
# Piston code execution engine (runs in Docker, see docker-compose.yml)
# Docker: http://piston:2000 | Local: http://localhost:2000
PISTON_URL="http://localhost:2000"

# ============================================
# WEB SEARCH (web_search agent tool)
# ============================================
# Two modes — same pattern as the KB pipeline:
#   perplexity (CLOUD default) — sonar-pro via OpenRouter. Turnkey answer + citations.
#   local     (ON-PREM)        — SearXNG → Serper → DuckDuckGo chain, no cloud calls.
WEB_SEARCH_MODE="perplexity"

# ----- MODE: perplexity (CLOUD) -----
# Which Perplexity model. Requires OPENROUTER_API_KEY set above.
#   perplexity/sonar                — cheapest, $1/M in+out
#   perplexity/sonar-pro            — default, $3/$15, strong answers + citations
#   perplexity/sonar-reasoning-pro  — $2/$8, chain-of-thought over search
# WEB_SEARCH_PERPLEXITY_MODEL="perplexity/sonar-pro"

# ----- MODE: local (ON-PREM) -----
# Search-provider priority within local mode:
#   (1) SERPER_API_KEY  — paid Google via Serper.dev ($0.001/search)
#   (2) SEARCH_API_URL  — self-hosted SearXNG (recommended for fully-air-gapped)
#   (3) DuckDuckGo      — keyless fallback (fragile HTML scrape)
# The bundled docker-compose.yml ships a SearXNG service; use it:
SEARCH_API_URL="http://localhost:8080/search"
# SERPER_API_KEY=""

# ============================================
# UNSPLASH (Optional - for contextual images in HTML artifacts)
# ============================================
# Resolves unsplash:keyword URLs to real photos in HTML artifacts
# Get your free API key at: https://unsplash.com/developers
# Without this, images fall back to placehold.co placeholders
# UNSPLASH_API_KEY=""

# ============================================
# WHATSAPP CHANNEL (Optional)
# ============================================
# Twilio configuration for WhatsApp integration
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="+14155238886"  # Twilio sandbox number

# ============================================
# EMAIL CHANNEL (Optional)
# ============================================
# SMTP settings for email notifications
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM=""

# ============================================
# BRANDING / WHITE-LABEL (Optional)
# ============================================
# Product mode controls branding across the entire platform
# "default" or unset: RantAI Agents (logos from /logo/)
# "nexus": NQRust Agents (logos from /nexus/)
# NEXT_PUBLIC_PRODUCT_MODE="default"

# ============================================
# MASTRA MEMORY (Optional)
# ============================================
# Use Mastra-style memory API for semantic recall (still uses PostgreSQL + SurrealDB)
# MASTRA_MEMORY_ENABLED="false"
# MASTRA_DUAL_WRITE="false"
# MASTRA_GRACEFUL_DEGRADATION="true"
# MASTRA_DEBUG="false"

# ============================================
# CLAIMS SERVICE API KEY (Optional)
# ============================================
# Used by external apps (e.g. HorizonLife) to access claims API
# CLAIMS_SERVICE_API_KEY="hlf_service_demo_key_2026"

# ============================================
# EXAMPLE CONFIGURATIONS
# ============================================
#
# --- CPU-Only Setup (No GPU) ---
# OCR_MODEL_DEFAULT="moondream"
# OCR_MODEL_HANDWRITTEN="qwen3-vl:2b"
# OCR_ENABLE_FALLBACK="true"
#
# --- Budget GPU (4-6GB VRAM) ---
# OCR_MODEL_DEFAULT="glm-ocr"
# OCR_MODEL_HANDWRITTEN="moondream"
# OCR_ENABLE_FALLBACK="true"
#
# --- Mid-Range GPU (8-12GB VRAM) ---
# OCR_MODEL_DEFAULT="glm-ocr"
# OCR_MODEL_HANDWRITTEN="qwen3-vl:8b"
# OCR_ENABLE_FALLBACK="true"
#
# --- High-End GPU (16GB+ VRAM) ---
# OCR_MODEL_DEFAULT="glm-ocr"
# OCR_MODEL_HANDWRITTEN="minicpm-v:4.5"
# OCR_ENABLE_FALLBACK="true"
#
# --- Cloud-Only (No Local OCR) ---
# OLLAMA_ENDPOINT=""
# OCR_ENABLE_FALLBACK="true"

# Artifact — React quality upgrade (2026-04-24)
# Set to "false" to disable hard-error on missing `// @aesthetic:` directive
# in react artifacts. Use only as an emergency rollback; normal operation
# leaves this unset (defaults to true = enforcement on).
ARTIFACT_REACT_AESTHETIC_REQUIRED=
# OCR_FALLBACK_MODEL="openai/gpt-4o-mini"

# ============================================
# ARTIFACT — Text/Document Script-Based Pipeline
# ============================================
# Cap on concurrent render jobs (sandbox + libreoffice). Default 3.
# Each render uses ~300MB peak. Pick a value that keeps total under host RAM.
RENDER_CONCURRENCY=3

# Comma-separated user ids allowed to call /api/admin/render-metrics.
ADMIN_USER_IDS=
