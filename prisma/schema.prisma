generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User role enum
enum Role {
  USER
  ADMIN
}

// User model (platform users — renamed from Agent, keeps same DB table)
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String
  role          Role           @default(USER)
  status        String         @default("OFFLINE") // ONLINE, BUSY, AWAY, OFFLINE (for live chat)
  avatarS3Key   String?        // S3 key for avatar image
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  @@map("Agent")
}

// Conversation session between customer and AI/agent
model Conversation {
  id              String    @id @default(cuid())
  sessionId       String    @unique
  status          String    @default("AI_ACTIVE") // AI_ACTIVE, HANDOFF_REQUESTED, WAITING_FOR_AGENT, AGENT_CONNECTED, RESOLVED
  channel         String    @default("PORTAL") // PORTAL, SALESFORCE, WHATSAPP, EMAIL
  externalId      String?   // External system ID (Salesforce Case ID, etc.)
  productInterest String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  agentId         String?
  agent           User?     @relation(fields: [agentId], references: [id])
  messages        Message[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  handoffAt       DateTime?
  resolvedAt      DateTime?

  @@index([status])
  @@index([channel])
  @@index([agentId])
  @@index([createdAt])
}

// Individual messages in a conversation
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // USER, ASSISTANT, AGENT, SYSTEM
  content        String
  metadata       String?      // JSON string for channel-specific data (WhatsApp message ID, etc.)
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  @@index([conversationId])
}

// Callback requests for when no agents are available
model CallbackRequest {
  id              String   @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  productInterest String?
  notes           String?
  status          String   @default("PENDING") // PENDING, CONTACTED, COMPLETED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Channel configuration for multi-channel agent communication
model ChannelConfig {
  id        String   @id @default(cuid())
  channel   String   @unique // PORTAL, SALESFORCE, WHATSAPP, EMAIL
  enabled   Boolean  @default(false)
  isPrimary Boolean  @default(false)
  config    Json     @default("{}") // Channel-specific configuration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Feature configuration for enabling/disabling application capabilities
model FeatureConfig {
  id        String   @id @default(cuid())
  feature   String   @unique // AGENT, KNOWLEDGE, CHAT
  enabled   Boolean  @default(true)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Organization/Workspace for multi-tenancy
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // URL-friendly identifier
  logoUrl     String?          // External URL for logo (backward compat)
  logoS3Key   String?          // S3 key for uploaded logo
  plan        String   @default("free") // free, starter, pro, enterprise

  // Limits based on plan
  maxMembers    Int @default(5)
  maxAssistants Int @default(3)
  maxDocuments  Int @default(100)
  maxApiKeys    Int @default(2)

  // Relationships
  memberships       OrganizationMember[]
  assistants        Assistant[]
  documents         Document[]
  groups            KnowledgeBaseGroup[]
  embedKeys         EmbedApiKey[]
  dashboardSessions DashboardSession[]
  usageRecords      UsageRecord[]
  tools             Tool[]
  skills            Skill[]
  mcpServers        McpServerConfig[]
  mcpApiKeys        McpApiKey[]
  workflows         Workflow[]
  credentials       Credential[]
  openApiSpecs      OpenApiSpec[]
  marketplaceInstalls MarketplaceInstall[]
  installedSkills     InstalledSkill[]
  digitalEmployees    DigitalEmployee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Organization membership (links users to orgs)
model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String       // From NextAuth session
  userEmail      String       // For display/invite
  userName       String?      // Cached user name
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       @default("member") // owner, admin, member, viewer
  invitedBy      String?      // userId who invited
  invitedAt      DateTime     @default(now())
  acceptedAt     DateTime?    // null = pending invite

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([userEmail])
}

// Usage tracking for analytics
model UsageRecord {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?      // Who triggered (optional)

  // What was used
  resourceType String  // "chat", "embedding", "api_call"
  resourceId   String? // assistantId, documentId, etc.

  // Metrics
  tokensInput  Int      @default(0)
  tokensOutput Int      @default(0)
  cost         Decimal? // Estimated cost in USD

  metadata  Json?    // Additional context
  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([resourceType])
}

// AI Assistant configuration for chat
model Assistant {
  id                    String        @id @default(cuid())
  name                  String
  description           String?
  emoji                 String        @default("🤖")
  systemPrompt          String        @db.Text
  model                 String        @default("xiaomi/mimo-v2-flash") // LLM model ID from OpenRouter
  useKnowledgeBase      Boolean       @default(false)
  knowledgeBaseGroupIds String[]      // Array of KnowledgeBaseGroup IDs
  isSystemDefault       Boolean       @default(false) // Global default assistant
  isBuiltIn             Boolean       @default(false) // Non-deletable built-in assistants

  // Organization scope (null = system/global assistant)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String?       // userId who created
  updatedBy      String?       // userId who last updated

  // Live Chat handoff — when enabled, widget can escalate to human agents
  liveChatEnabled Boolean @default(false)

  // Avatar image (S3 key, null = use emoji)
  avatarS3Key String?

  // Model parameters per-assistant
  modelConfig Json? // { temperature?, topP?, maxTokens?, presencePenalty?, frequencyPenalty?, reasoningEffort? }

  // Opening/onboarding settings
  openingMessage  String?  @db.Text // Welcome message shown when conversation starts
  openingQuestions String[] // Conversation starter suggestions

  // Guard rails / safety settings
  guardRails Json? // { blockedTopics?, safetyInstructions?, maxResponseLength?, requireCitations? }

  // Chat preferences per-assistant
  chatConfig Json? // { autoCreateTopic?, messageThreshold?, limitHistory?, historyCount?, autoSummary?, autoScroll? }

  // Memory configuration per-assistant
  memoryConfig Json? // { enabled, workingMemory, semanticRecall, longTermProfile, memoryInstructions }

  // User-defined tags for filtering
  tags String[]

  // Tool bindings
  tools AssistantTool[]

  // Skill bindings
  skills AssistantSkill[]

  // MCP server bindings
  mcpServers AssistantMcpServer[]

  // Workflow bindings (many-to-many via junction table)
  assistantWorkflows AssistantWorkflow[]

  // Workflows (legacy direct FK)
  workflows Workflow[]

  // Digital Employee bindings
  digitalEmployees DigitalEmployee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// User preferences including default assistant selection
model UserPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique // From NextAuth session
  defaultAssistantId String?  // User's chosen default (overrides system default)
  sidebarConfig      Json?    // { hiddenItems: string[], sidebarCollapsed: boolean }
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Category model for document classification
model Category {
  id        String   @id @default(cuid())
  name      String   @unique // Internal name: "LIFE_INSURANCE", "CUSTOM_CAT"
  label     String            // Display label: "Life Insurance"
  color     String            // Hex color: "#3b82f6"
  isSystem  Boolean  @default(false) // True for default categories (prevent deletion)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Knowledge base groups/folders for organizing documents
model KnowledgeBaseGroup {
  id          String          @id @default(cuid())
  name        String
  description String?
  color       String?         // Hex color for UI display
  documents   DocumentGroup[]

  // Organization scope (null = global/shared)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String?       // userId who created

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// Junction table for many-to-many Document <-> KnowledgeBaseGroup
model DocumentGroup {
  id        String             @id @default(cuid())
  documentId String
  groupId    String
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  group      KnowledgeBaseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())

  @@unique([documentId, groupId])
  @@index([documentId])
  @@index([groupId])
}

// Knowledge base documents for RAG
// Note: Document chunks are stored in SurrealDB for vector search
model Document {
  id          String          @id @default(cuid())
  title       String
  content     String
  categories  String[]        // Array of categories: LIFE_INSURANCE, HEALTH_INSURANCE, HOME_INSURANCE, FAQ, POLICY, GENERAL
  subcategory String?         // Plan names, specific topics
  metadata    Json?           // Additional structured data (legacy: may contain fileData as base64)
  groups      DocumentGroup[]

  // S3 file storage (replaces base64 in metadata)
  s3Key       String?         // S3 object key for original file
  fileType    String?         // "pdf", "image", "markdown"
  fileSize    Int?            // File size in bytes
  mimeType    String?         // MIME type (e.g., "application/pdf")

  // Organization scope (null = global/shared)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String?       // userId who created

  // Artifact association (null = regular knowledge document)
  sessionId    String?
  session      DashboardSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  artifactType String?           // "text/html" | "application/react" | etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([s3Key])
  @@index([sessionId])
}

// API Key for embeddable chat widget
model EmbedApiKey {
  id             String    @id @default(cuid())
  name           String    // Human-readable name (e.g., "Company Website")
  key            String    @unique // Generated API key (e.g., "rantai_live_...")
  assistantId    String    // Assistant to use for this key

  // Domain security
  allowedDomains String[]  // e.g., ["example.com", "*.example.com"]

  // Widget customization (JSON)
  config         Json      @default("{}") // { theme, position, welcomeMessage, avatar, cssClass, launcherButton }

  // Usage tracking
  requestCount   Int       @default(0)
  lastUsedAt     DateTime?

  // Organization scope (required for API keys)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String?       // userId who created

  // Management
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([key])
  @@index([assistantId])
  @@index([organizationId])
}

// Dashboard chat sessions (separate from widget conversations)
model DashboardSession {
  id          String             @id @default(cuid())
  userId      String             // From NextAuth session
  title       String             @default("New Chat")
  assistantId String
  messages    DashboardMessage[]
  artifacts   Document[]         // Artifacts created in this session

  // Organization context (optional - for shared/team chats)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([assistantId])
  @@index([organizationId])
}

// Messages in dashboard chat sessions
model DashboardMessage {
  id          String           @id @default(cuid())
  sessionId   String
  session     DashboardSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String           // "user" or "assistant"
  content     String           @db.Text
  replyTo     String?          // ID of the message being replied to
  editHistory Json?            // Array of { content, assistantResponse, editedAt }
  sources     Json?            // Array of sources for assistant messages
  metadata    Json?            // Extra data e.g. { artifactIds: string[] }
  attachments FileAttachment[] // File attachments for this message
  createdAt   DateTime         @default(now())

  @@index([sessionId])
}

// File attachments stored in S3
model FileAttachment {
  id          String   @id @default(cuid())

  // S3 storage
  s3Key       String   @unique  // S3 object key
  s3Bucket    String   @default("rantai-files")

  // File metadata
  filename    String            // Original filename
  contentType String            // MIME type
  size        Int               // File size in bytes

  // Owner
  uploadedBy  String?           // userId who uploaded

  // Relations (optional - attachment can be orphaned temporarily)
  messageId   String?
  message     DashboardMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([messageId])
  @@index([uploadedBy])
}

// Memory type enum for agentic memory system
enum MemoryType {
  WORKING
  SEMANTIC
  LONG_TERM
}

// User memory storage for agentic memory system
model UserMemory {
  id          String     @id @default(cuid())
  userId      String
  type        MemoryType
  key         String
  value       Json
  embedding   Float[]    // For semantic search (empty array if not set)
  confidence  Float?
  source      String?    // Which conversation/message
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  expiresAt   DateTime?  // For working memory TTL

  @@index([userId, type])
  @@index([userId, type, key])
  @@index([key])
}

// Tool definition for agentic capabilities
model Tool {
  id              String   @id @default(cuid())
  name            String                          // Machine name: "knowledge_search"
  displayName     String                          // Human name: "Knowledge Base Search"
  description     String   @db.Text               // LLM-facing description
  category        String   @default("builtin")    // "builtin" | "custom" | "mcp"
  parameters      Json                            // Zod-compatible JSON schema
  icon            String?                         // Emoji or Lucide icon name for display
  tags            String[]                        // Tags for filtering/discovery
  isBuiltIn       Boolean  @default(false)
  enabled         Boolean  @default(true)
  executionConfig Json?                           // For custom: { type, url, method, headers }

  // MCP association (null for builtin/custom tools)
  mcpServerId String?
  mcpServer   McpServerConfig? @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  // OpenAPI spec association (null for non-openapi tools)
  openApiSpecId String?

  // Organization scope (null = system/global tool)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String?

  // Tool-Assistant bindings
  assistantTools AssistantTool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, organizationId])
  @@index([organizationId])
  @@index([category])
  @@index([mcpServerId])
}

// Junction table: which tools are enabled for which assistant
model AssistantTool {
  id          String    @id @default(cuid())
  assistantId String
  assistant   Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  toolId      String
  tool        Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([assistantId, toolId])
  @@index([assistantId])
  @@index([toolId])
}

// Junction table: which MCP servers are enabled for which assistant
model AssistantMcpServer {
  id          String          @id @default(cuid())
  assistantId String
  assistant   Assistant       @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  mcpServerId String
  mcpServer   McpServerConfig @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now())

  @@unique([assistantId, mcpServerId])
  @@index([assistantId])
  @@index([mcpServerId])
}

model AssistantWorkflow {
  id          String    @id @default(cuid())
  assistantId String
  assistant   Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  workflowId  String
  workflow    Workflow  @relation("AssistantWorkflows", fields: [workflowId], references: [id], onDelete: Cascade)
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([assistantId, workflowId])
  @@index([assistantId])
  @@index([workflowId])
}

// MCP Server configuration for external tool providers (remote-only: SSE or streamable-http)
model McpServerConfig {
  id              String    @id @default(cuid())
  name            String
  description     String?
  transport       String                          // "sse" | "streamable-http"
  url             String?                         // Server endpoint URL
  env             Json?                           // Environment variables (encrypted)
  headers         Json?                           // HTTP auth headers (encrypted)
  icon            String?                         // Emoji or Lucide icon name or image URL
  isBuiltIn       Boolean   @default(false)       // Pre-installed = non-deletable
  envKeys         Json?                           // Array<{key, label, placeholder}> for config UI
  docsUrl         String?                         // Link to provider documentation
  enabled         Boolean   @default(true)
  configured      Boolean   @default(true)        // false = needs env/config from user
  lastConnectedAt DateTime?
  lastError       String?

  // Discovered tools
  tools Tool[]

  // Assistant bindings
  assistantMcpServers AssistantMcpServer[]

  // Organization scope
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// Tool execution log for tracking and debugging
model ToolExecution {
  id          String   @id @default(cuid())
  toolName    String
  toolId      String?
  assistantId String?
  sessionId   String?
  input       Json
  output      Json?
  error       String?
  durationMs  Int?
  status      String   @default("pending") // "pending" | "success" | "error"
  organizationId String?
  userId         String?
  createdAt   DateTime @default(now())

  @@index([toolName, createdAt])
  @@index([sessionId])
  @@index([organizationId, createdAt])
}

model McpApiKey {
  id             String    @id @default(cuid())
  name           String
  key            String    @unique
  exposedTools   String[]
  requestCount   Int       @default(0)
  lastUsedAt     DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([key])
  @@index([organizationId])
}

// ─── Credential Management ──────────────────────────────────

model Credential {
  id              String   @id @default(cuid())
  name            String
  type            String   // "api_key", "oauth2", "basic_auth", "bearer"
  encryptedData   String   @db.Text // AES-256-GCM encrypted JSON
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}

// ─── Workflow Builder ────────────────────────────────────────

model Workflow {
  id              String         @id @default(cuid())
  name            String
  description     String?

  // Canvas data (React Flow format)
  nodes           Json           @default("[]")
  edges           Json           @default("[]")

  // Metadata
  trigger         Json           @default("{\"type\":\"manual\"}")
  variables       Json           @default("{\"inputs\":[],\"outputs\":[]}")

  // Execution mode
  mode            WorkflowMode   @default(STANDARD)
  category        WorkflowCategory @default(AUTOMATION)
  chatflowConfig  Json           @default("{}")

  // Public API access
  apiEnabled      Boolean        @default(false)
  apiKey          String?        @unique

  // Status
  status          WorkflowStatus @default(DRAFT)
  version         Int            @default(1)

  // User-defined tags for filtering
  tags            String[]

  // Relations
  organizationId  String?
  organization    Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       String
  assistantId     String?
  assistant       Assistant?     @relation(fields: [assistantId], references: [id], onDelete: SetNull)

  runs            WorkflowRun[]
  assistantWorkflows AssistantWorkflow[] @relation("AssistantWorkflows")

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
  @@index([assistantId])
}

model WorkflowRun {
  id              String     @id @default(cuid())
  workflowId      String
  workflow        Workflow    @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status          RunStatus
  input           Json
  output          Json?
  error           String?

  // Execution trace
  steps           Json       @default("[]")
  suspendedAt     String?    // Step ID where execution is suspended (HITL)
  resumeData      Json?

  startedAt       DateTime   @default(now())
  completedAt     DateTime?

  @@index([workflowId, startedAt])
}

enum WorkflowMode {
  STANDARD   // Execute once, return result
  CHATFLOW   // Handle chat messages, support streaming
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowCategory {
  TASK        // Attachable to agents as jobs they execute
  CHATFLOW    // Conversation flow (existing CHATFLOW mode)
  AUTOMATION  // Standalone pipeline (existing STANDARD mode)
}

enum RunStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

// ─── Insurance models removed in Fase 8 ─────────────────────
// InsuranceCustomer, InsurancePolicy, Provider, Claim models
// have been migrated to HorizonLife-Demo (merged into Customer/Policy models).
// RantAI-Agents now serves as pure workflow service provider only.

// ─── Skills System (OpenClaw / Custom) ──────────────────────

model Skill {
  id             String   @id @default(cuid())
  name           String
  displayName    String
  description    String   @db.Text
  content        String   @db.Text             // Skill prompt markdown
  source         String   @default("custom")   // "openclaw" | "custom" | "marketplace"
  sourceUrl      String?                       // ClawHub URL
  version        String?
  category       String   @default("general")  // "productivity", "coding", "writing", etc.
  tags           String[]
  icon           String?                       // Emoji or Lucide icon name for display
  metadata       Json?                         // OpenClaw frontmatter
  enabled        Boolean  @default(true)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String?
  assistantSkills AssistantSkill[]
  installedSkill InstalledSkill?        // Reverse relation if linked from InstalledSkill
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([name, organizationId])
  @@index([organizationId])
}

model AssistantSkill {
  id          String   @id @default(cuid())
  assistantId String
  assistant   Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  skillId     String
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  @@unique([assistantId, skillId])
  @@index([assistantId])
  @@index([skillId])
}

// ─── Installed Community Skills ──────────────────────────────

model InstalledSkill {
  id             String   @id @default(cuid())
  name           String                          // Community skill registry key: "neko-finance"
  displayName    String
  description    String   @db.Text
  version        String                          // Installed version: "1.0.0"
  category       String   @default("general")
  tags           String[]
  icon           String   @default("Sparkles")
  skillPrompt    String   @db.Text               // SKILL.md content snapshot
  configSchema   Json?                           // JSON Schema for user config form
  config         Json?                           // User-provided config values (API keys, etc.)
  enabled        Boolean  @default(true)

  // Organization scope
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  installedBy    String?

  // Linked Skill record for prompt injection
  skillId        String?  @unique
  skill          Skill?   @relation(fields: [skillId], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, organizationId])
  @@index([organizationId])
}

// ─── OpenAPI Spec Import ────────────────────────────────────

model OpenApiSpec {
  id           String   @id @default(cuid())
  name         String
  specUrl      String?
  specContent  Json
  version      String?
  serverUrl    String
  authConfig   Json?    // { type, token, headerName }
  toolCount    Int      @default(0)
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([organizationId])
}

// ─── Tool Marketplace ───────────────────────────────────────

model MarketplaceInstall {
  id             String   @id @default(cuid())
  catalogItemId  String
  itemType       String   // "tool" | "skill"
  installedId    String   // Created Tool.id or Skill.id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  installedBy    String?
  createdAt      DateTime @default(now())
  @@unique([catalogItemId, organizationId])
  @@index([organizationId])
}

model CatalogItem {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  description   String   @db.Text
  category      String
  type          String   // "tool" | "skill" | "workflow" | "assistant"
  icon          String   @default("Sparkles")
  tags          String[]
  featured      Boolean  @default(false)
  skillContent  String?  @db.Text
  skillCategory String?
  toolTemplate  Json?
  workflowTemplate Json?
  assistantTemplate Json?
  mcpTemplate   Json?
  sourceUrl     String?
  sourceSlug    String?  @unique

  // Community package references
  communitySkillName String?               // Maps to CommunitySkillDefinition.name in registry
  communityToolName  String?               // Maps to CommunityToolDefinition.name in registry
  configSchema       Json?                 // JSON Schema for skill config form on install

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Digital Employee System ──────────────────────────────────

enum EmployeeStatus {
  DRAFT
  ONBOARDING
  ACTIVE
  PAUSED
  SUSPENDED
  ARCHIVED
}

enum ApprovalStatus {
  PENDING
  DELIVERED
  APPROVED
  REJECTED
  EDITED
  EXPIRED
  CANCELLED
}

model DigitalEmployee {
  id               String          @id @default(cuid())
  name             String
  description      String?
  avatar           String?
  status           EmployeeStatus  @default(DRAFT)
  assistantId      String
  assistant        Assistant       @relation(fields: [assistantId], references: [id])
  deploymentConfig Json            @default("{}")
  resourceLimits   Json?
  autonomyLevel    String          @default("supervised") // "supervised" | "autonomous"
  runtimeId        String?
  lastActiveAt     DateTime?
  lastRunId        String?
  supervisorId     String?
  gatewayConfig    Json?
  totalRuns        Int             @default(0)
  successfulRuns   Int             @default(0)
  failedRuns       Int             @default(0)
  totalTokensUsed  BigInt          @default(0)
  containerId      String?         // Docker container ID when running
  containerPort    Int?            // Mapped host port for RantaiClaw gateway
  gatewayToken     String?         // Runtime JWT for gateway proxy
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  runs             EmployeeRun[]
  approvals        EmployeeApproval[]
  files            EmployeeFile[]
  customTools      EmployeeCustomTool[]
  installedSkills  EmployeeInstalledSkill[]
  memoryEntries    EmployeeMemory[]
  chatMessages     EmployeeChatMessage[]

  @@index([organizationId])
  @@index([status])
  @@index([assistantId])
}

model EmployeeRun {
  id                String          @id @default(cuid())
  digitalEmployeeId String
  digitalEmployee   DigitalEmployee @relation(fields: [digitalEmployeeId], references: [id], onDelete: Cascade)
  trigger           String          // "schedule" | "webhook" | "manual" | "event"
  triggerData       Json?
  workflowId        String?
  workflowRunId     String?
  status            RunStatus
  output            Json?
  error             String?
  promptTokens      Int             @default(0)
  completionTokens  Int             @default(0)
  executionTimeMs   Int?
  startedAt         DateTime        @default(now())
  completedAt       DateTime?

  @@index([digitalEmployeeId, startedAt])
}

model EmployeeApproval {
  id                String          @id @default(cuid())
  digitalEmployeeId String
  digitalEmployee   DigitalEmployee @relation(fields: [digitalEmployeeId], references: [id], onDelete: Cascade)
  employeeRunId     String
  workflowStepId    String?
  requestType       String
  title             String
  description       String?
  content           Json
  options           Json
  channel           String          @default("dashboard")
  status            ApprovalStatus  @default(PENDING)
  respondedBy       String?
  response          String?
  responseData      Json?
  respondedAt       DateTime?
  expiresAt         DateTime?
  timeoutAction     String?
  createdAt         DateTime        @default(now())

  @@index([digitalEmployeeId, status])
  @@index([status, expiresAt])
}

model EmployeeFile {
  id                String          @id @default(cuid())
  digitalEmployeeId String
  digitalEmployee   DigitalEmployee @relation(fields: [digitalEmployeeId], references: [id], onDelete: Cascade)
  filename          String
  content           String          @db.Text
  updatedBy         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([digitalEmployeeId, filename])
  @@index([digitalEmployeeId])
}

model EmployeeCustomTool {
  id                String          @id @default(cuid())
  digitalEmployeeId String
  digitalEmployee   DigitalEmployee @relation(fields: [digitalEmployeeId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  parameters        Json
  code              String          @db.Text
  language          String          @default("javascript")
  enabled           Boolean         @default(true)
  approved          Boolean         @default(false)
  createdBy         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([digitalEmployeeId])
}

model EmployeeInstalledSkill {
  id                String          @id @default(cuid())
  digitalEmployeeId String
  digitalEmployee   DigitalEmployee @relation(fields: [digitalEmployeeId], references: [id], onDelete: Cascade)
  slug              String
  name              String
  version           String
  description       String?
  content           String          @db.Text
  metadata          Json?
  source            String          @default("clawhub")
  enabled           Boolean         @default(true)
  installedBy       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([digitalEmployeeId, slug])
  @@index([digitalEmployeeId])
}

model EmployeeMemory {
  id                String          @id @default(cuid())
  digitalEmployeeId String
  digitalEmployee   DigitalEmployee @relation(fields: [digitalEmployeeId], references: [id], onDelete: Cascade)
  type              String
  date              String?
  content           String          @db.Text
  embedding         Float[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([digitalEmployeeId, type])
  @@index([digitalEmployeeId, date])
}

model EmployeeChatMessage {
  id                String          @id @default(cuid())
  digitalEmployeeId String
  digitalEmployee   DigitalEmployee @relation(fields: [digitalEmployeeId], references: [id], onDelete: Cascade)
  role              String          // "user" | "assistant"
  content           String          @db.Text
  toolCalls         Json?           // Parsed tool call metadata
  createdAt         DateTime        @default(now())

  @@index([digitalEmployeeId, createdAt])
}
